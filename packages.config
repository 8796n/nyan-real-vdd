<?xml version="1.0" encoding="utf-8"?>
<!--
  WDK/SDK for build machines that do not have the kits installed (CI).
  Restored into packages\ by `nuget restore`; Directory.Build.props picks them
  up only when they are present, so a developer machine with the WDK installed
  keeps building exactly as before.
-->
<packages>
  <package id="Microsoft.Windows.SDK.CPP" version="10.0.28000.1839" targetFramework="native" />
  <package id="Microsoft.Windows.SDK.CPP.x64" version="10.0.28000.1839" targetFramework="native" />
  <package id="Microsoft.Windows.WDK.x64" version="10.0.28000.1839" targetFramework="native" />
</packages>
