    <TargetFrameworkVersion>v4.5</TargetFrameworkVersion>
    <MinimumVisualStudioVersion>12.0</MinimumVisualStudioVersion>
    <Configuration>Debug</Configuration>
    <Platform Condition="'$(Platform)' == ''">x64</Platform>
    <RootNamespace>nyanvdd</RootNamespace>
    <!--
      IddCx version strategy: build against the 1.10 headers (HDR-capable *2
      DDIs) with a 1.10 runtime floor — supported OS is Windows 11 24H2+
      (everything older is EOL; the INF decoration 10.0...26100 is the
      enforcement point). Features beyond 1.10 (e.g. 1.11 D3D12) stay gated
      on IddCxGetVersion at runtime.
    -->
    <NyanIddCxMinor Condition="'$(NyanIddCxMinor)' == ''">10</NyanIddCxMinor>
    <NyanIddCxMinimumRequired Condition="'$(NyanIddCxMinimumRequired)' == ''">10</NyanIddCxMinimumRequired>
    <!--
      stampinf stamps DriverVer with the LOCAL date while Inf2Cat validates it
      against UTC, so east-of-UTC time zones fail with "postdated DriverVer"
      for the first hours of every local day (JST 00:00-09:00).
    -->
    <Inf2CatUseLocalTime>true</Inf2CatUseLocalTime>
  </PropertyGroup>
  <PropertyGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <PlatformToolset>WindowsUserModeDriver10.0</PlatformToolset>
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <DriverTargetPlatform>Universal</DriverTargetPlatform>
  </PropertyGroup>
  <PropertyGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <PlatformToolset>WindowsUserModeDriver10.0</PlatformToolset>
