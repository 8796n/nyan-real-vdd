    <IDDCX_VERSION_MINOR>$(NyanIddCxMinor)</IDDCX_VERSION_MINOR>
    <Driver_SpectreMitigation>false</Driver_SpectreMitigation>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings">
